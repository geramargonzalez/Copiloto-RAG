# Shared
APP_ALLOWED_ROLES=finance,sales,support,admin
PII_BLOCKLIST_PATTERNS=\b\d{11}\b

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/copiloto

# LLM OpenAI-compatible
LLM_BASE_URL=https://api.openai.com
LLM_API_KEY=replace_me
LLM_CHAT_MODEL=gpt-4o-mini
LLM_EMBED_MODEL=text-embedding-3-small
LLM_CHAT_PATH=/v1/chat/completions
LLM_EMBED_PATH=/v1/embeddings
LLM_MAX_TOKENS=900
LLM_TEMPERATURE=0.1
LLM_INPUT_COST_PER_1K=0.0
LLM_OUTPUT_COST_PER_1K=0.0
# Offline/local demo mode:
# LLM_BASE_URL=mock://local
# LLM_API_KEY=mock

# Auth / OIDC stub
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=dev-nextauth-secret-change-me
AUTH_JWT_SECRET=dev-api-jwt-secret-change-me
AUTH_OIDC_ISSUER=https://issuer.example.com
AUTH_OIDC_CLIENT_ID=oidc-client-id
AUTH_OIDC_CLIENT_SECRET=oidc-client-secret

# API runtime
PORT=4000
API_CORS_ORIGIN=http://localhost:3000
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=30
RETRIEVAL_TOPK=10
MAX_TOOL_RESULTS=3

# Web runtime
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000

# Eval
EVAL_API_URL=http://localhost:4000
EVAL_LIMIT=40
