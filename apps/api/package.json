{
  "name": "@copiloto/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/src/server.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint \"src/**/*.ts\" \"tests/**/*.ts\"",
    "test": "vitest run",
    "ingest": "tsx src/ingest/index.ts",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:generate": "drizzle-kit generate --config drizzle.config.ts",
    "eval:run": "tsx src/eval/run.ts"
  },
  "dependencies": {
    "@copiloto/shared": "workspace:*",
    "@fastify/cors": "^10.0.2",
    "cheerio": "^1.0.0",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.38.4",
    "fastify": "^5.2.1",
    "fastify-plugin": "^5.0.1",
    "jose": "^5.9.6",
    "pdf-parse": "^1.1.1",
    "pg": "^8.13.1",
    "postgres": "^3.4.5",
    "pino": "^9.6.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/pg": "^8.11.11",
    "@types/supertest": "^6.0.3",
    "drizzle-kit": "^0.30.1",
    "supertest": "^7.0.0",
    "tsx": "^4.19.2",
    "vitest": "^2.1.8"
  }
}

